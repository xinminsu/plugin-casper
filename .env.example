# Casper Node Configuration
# 使用公共 RPC 节点（无需 API Key）
CASPER_NODE_URL=https://rpc.testnet.cspr.cloud:443/rpc

# Optional: Default wallet (for automated operations)
# CASPER_PUBLIC_KEY=your_public_key_here
# CASPER_PRIVATE_KEY=your_private_key_here

# Chain name (optional, defaults to casper-test for testnet)
# CASPER_CHAIN_NAME=casper-test
