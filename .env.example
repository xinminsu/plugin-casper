# Casper Node Configuration
# Use public RPC nodes (no API Key required)
CASPER_NODE_URL=https://node.testnet.casper.network/rpc

# Optional: CSPR.cloud API key (required for authenticated nodes like node.testnet.cspr.cloud)
# CASPER_API_KEY=your_cspr_cloud_api_key_here

# Optional: Default wallet (for automated operations)
# CASPER_PUBLIC_KEY=your_public_key_here
# CASPER_PRIVATE_KEY=your_private_key_hex
# CASPER_SIGNING_KEY_HEX=your_private_key_hex
# Option A: inline PEM (use \n for line breaks in .env)
# Ed25519 (PKCS#8):
# CASPER_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEI...\n-----END PRIVATE KEY-----"
# Secp256k1 (EC):
# CASPER_SIGNING_KEY_PEM="-----BEGIN EC PRIVATE KEY-----\nMHQCAQEEI...\n-----END EC PRIVATE KEY-----"
# Option B: path to PEM file (recommended for multiline keys)
# CASPER_SIGNING_KEY_PEM_FILE=/path/to/secret_key.pem
# Optional override (auto-detected from PEM header when omitted):
# CASPER_KEY_ALGORITHM=ed25519
# CASPER_KEY_ALGORITHM=secp256k1

# Chain name (optional, defaults to casper-test for testnet)
# CASPER_CHAIN_NAME=casper-test
